# === AI Video Editor - Environment Variables ===
# Copy this to .env and fill in your values. NEVER commit .env with real keys.

# Google Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# NVIDIA NIM API Key (get from https://build.nvidia.com)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# AI Provider Selection: gemini, nvidia, or auto (tries gemini first, then nvidia)
AI_PROVIDER=auto

# API Authentication - clients must send X-API-Key header with this value
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=change_this_to_a_strong_random_secret

# Model Configuration
GEMINI_MODEL=gemini-2.5-flash

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS - comma-separated allowed origins (restrict to your frontend URL)
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Storage
UPLOAD_DIR=./storage/uploads
OUTPUT_DIR=./storage/outputs
TEMP_DIR=./storage/temp
MAX_UPLOAD_SIZE_MB=500

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./storage/projects.db

# Redis (for Celery task queue - optional)
REDIS_URL=redis://localhost:6379/0

# FFmpeg
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Video Output Settings
OUTPUT_RESOLUTION=1920x1080
OUTPUT_FPS=24
OUTPUT_CODEC=libx264
OUTPUT_PRESET=slow
OUTPUT_CRF=18

# Rate Limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=30

# Concurrency Control
MAX_CONCURRENT_RENDERS=2
